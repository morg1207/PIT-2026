<robot name="pitbot">


    <link name="base_footprint"/>

    <link name="chassis_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.15" length="0.07"/>
            </geometry>
        </visual>
        <material name="rojo">
            <color rgba="1.0 0.0 0.0 1.0"/>
        </material>
    </link>
    <joint name="base_footprint_chasis_joint" type="fixed">
        <origin xyz="0.0 0.0 0.07" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="chassis_link"/>
    </joint>


    <link name="rueda_derecha_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.07" length="0.03"/>
            </geometry>
            <material name="negro">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        
    </link>

    <joint name="rueda_derecha_chasis_joint" type="continuous">
        <origin xyz="0.0 -0.15 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="chassis_link"/>
        <child link="rueda_derecha_link"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>


    <link name="rueda_izquierda_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <geometry>
                <cylinder radius="0.07" length="0.03"/>
            </geometry>
            <material name="negro">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
    </link>
    <joint name="rueda_izquierda_chasis_joint" type="continuous">
        <origin xyz="0.0 0.15 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="chassis_link"/>
        <child link="rueda_izquierda_link"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>
</robot>


